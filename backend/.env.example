# Database (default uses a local SQLite file inside the container)
# DATABASE_URL=sqlite+aiosqlite:////app/data/rss_reader.db

# Ollama LLM service
# OLLAMA_BASE_URL=http://ollama:11434
# OLLAMA_MODEL=qwen3.5:9b

# RSSHub feed conversion service
# RSSHUB_BASE_URL=http://rsshub:1200

# Daily digest generation time (HH:MM, 24h)
# DIGEST_TIME=07:00

# Feed poll interval in seconds (min 60, max 86400)
# FETCH_INTERVAL=3600
